  st_as_sf(coords = c("longitude", "latitude"),
           crs = 4326) %>%
  st_transform(6440)


Disease_incidence <- subset(Disease_incidence, select = -sites_id)
Degree_centrality <- subset(Degree_centrality, select = -sites_id)



# April
# Network 1


Disease_incidence$DiseaseinApril <- weather$DiseaseinApril
Degree_centrality$Weighted_dc_aprmay1 <- weather$Weighted_dc_aprmay1

# https://r-spatial.github.io/mapview/articles/mapview_02-advanced.html
map <- mapview(Disease_incidence, ycol = "DiseaseinApril",  
               col.regions=brewer.pal(5, "Accent"),lwd = 0.000,
               legend = TRUE) + 
  mapview(Degree_centrality, cex = "Weighted_dc_aprmay1", lwd = 2, 
          col.regions=brewer.pal(5, "Accent"), alpha.regions = 0.00000000000000001,
          legend = FALSE)


# Add a title to the map
map@map <- map@map %>%
  addControl("<h2>2014 April Network 1 </h2>", position = "bottomleft", className = "map-title")

map

