# Loading library
library(ggplot2)


dfplot <- read.csv(".../pred_cost_June_github.csv", check.names=FALSE)
ggplot(data=dfplot, aes(x=Mildew_incidence_in_May, y=pred, color=interaction(month))) +
  geom_line() +  xlim(0, 1) + ylim(0, 400) +
  scale_color_manual("groups",
                     values=c("#61d4b3","#fb8d62"))+
  xlab("Mildew incidence in May") + ylab("Predicted monthly costs in June")+ 
  theme(panel.background = element_blank(), axis.line = element_line(colour = "black"))

