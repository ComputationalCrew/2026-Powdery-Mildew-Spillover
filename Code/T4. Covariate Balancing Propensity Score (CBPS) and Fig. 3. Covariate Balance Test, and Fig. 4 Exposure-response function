#================================================
# 1. Generating pseudo population 
# Data weighted for matched to make the distribution of pre-exposure covariates 
# align across different exposure levels = achieving covariate balance.)
#================================================

m_xgboost <- function(nthread = 1,
                      ntrees = 1000,
                      shrinkage = 0.3,
                      max_depth = 5,
                      ...) {SuperLearner::SL.xgboost(
                        nthread = nthread,
                        ntrees = ntrees,
                        shrinkage=shrinkage,
                        max_depth=max_depth,
                        ...)}


#================================================
# Disease incidence in May
#================================================


data_with_gps <- estimate_gps(.data = df_v1,
                              .formula = Mildew_incidence_in_May~ Susceptibility_to_R6_strains+Susceptibility_to_non_R6_strains+
                                Flag_shoot_incidence+Pruning+
                                Initial_Strain+Degree_May_Jun_1+
                                Degree_May_Jun_2+Quadrant+Synthetic_in_April+Nonsynthetic_in_April+Mixture_in_April,
                              sl_lib = c("m_xgboost"),
                              gps_density = "kernel")



cw_object_matching <- compute_counter_weight(gps_obj = data_with_gps,
                                             ci_appr = "weighting",
                                             bin_seq = NULL, 
                                             delta_n = 0.1,
                                             dist_measure = "l1",
                                             scale = 0.5,
                                             use_cov_transform = TRUE,
                                             transformers = list("pow2", "pow3", "abs", 
                                                                 "scale"),
                                             exposure_trim_qtls = c(0.01,0.99),
                                             sl_lib = c("m_xgboost"),
                                             max_attempt = 4,
                                             dist_measure = "l1",
                                             delta_n = 0.02,          # changed from 1 to 0.02
                                             scale = 0.5,
                                             nthread = 1)


pseudo_pop <- generate_pseudo_pop(.data = df_v1,
                                  cw_obj = cw_object_matching,
                                  covariate_col_names = c("Susceptibility_to_R6_strains", 
                                                          "Susceptibility_to_non_R6_strains", 
                                                          "Flag_shoot_incidence", "Pruning", "Initial_Strain", 
                                                          "Degree_May_Jun_1", "Degree_May_Jun_2", "Quadrant", 
                                                          "Synthetic_in_April","Nonsynthetic_in_April",
                                                          "Mixture_in_April"),
                                  covar_bl_trs = 0.3,
                                  covar_bl_trs_type = "median",
                                  covar_bl_method = "absolute")


png("pseudo_pop_May.png", width=6000,height=7000, res=1000)
plot(pseudo_pop, include_details = TRUE) + theme(panel.grid.major = element_blank(), panel.grid.minor = element_blank(),
                                                 panel.background = element_blank(), axis.line = element_line(colour = "black")) 
dev.off()

plot(pseudo_pop)


# ERF
# Annual costs
erf_obj_nonparametric <- estimate_erf(.data = pseudo_pop$.data,
                                      .formula = Monthly_cost_June ~ Mildew_incidence_in_May*Degree_May_Jun_1,
                                      weights_col_name = "counter_weight",
                                      model_type = "nonparametric",
                                      w_vals = seq(0,0.38,0.02),
                                      bw_seq = seq(0.2,2,0.2),
                                      kernel_appr = "kernsmooth")


erf_obj_nonparametric[[".data_prediction"]][["w_vals"]]

erf_obj_nonparametric[[".data_prediction"]][["y_pred"]]



# Active ingredients
erf_obj_nonparametric <- estimate_erf(.data = pseudo_pop$.data,
                                      .formula = Monthly_ingredient_June ~ Mildew_incidence_in_May,
                                      weights_col_name = "counter_weight",
                                      model_type = "nonparametric",
                                      w_vals = seq(0,0.38,0.02),
                                      bw_seq = seq(0.2,2,0.2),
                                      kernel_appr = "kernsmooth")


erf_obj_nonparametric[[".data_prediction"]][["w_vals"]]

erf_obj_nonparametric[[".data_prediction"]][["y_pred"]]



# Fit CBPS model
cbps_model <- CBPS(Mildew_incidence_in_May ~ Susceptibility_to_R6_strains
                   + Susceptibility_to_non_R6_strains+
                     Flag_shoot_incidence+Pruning+
                     Initial_Strain+Degree_May_Jun_1+
                     Degree_May_Jun_2 + Quadrant+Synthetic_in_April+Nonsynthetic_in_April+
                     Mixture_in_April, 
                   method = "exact", data = df_v1, ATT=TRUE)

summary(cbps_model)


